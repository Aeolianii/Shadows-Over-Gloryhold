OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional dedicated DeepSeek agents. If omitted, they fall back to DEEPSEEK_API_KEY.
DEEPSEEK_GM_API_KEY=
DEEPSEEK_STORY_API_KEY=
DEEPSEEK_WORLD_STATE_API_KEY=
DEEPSEEK_NPC_API_KEY=
DEEPSEEK_OBSERVATION_API_KEY=
DEEPSEEK_ACTION_PARSER_API_KEY=
DEEPSEEK_RECOMMENDATION_API_KEY=

# Optional speed/transport controls. Defaults ignore system proxy variables to avoid SOCKS dependency failures.
AI_HTTP_TRUST_ENV=false
AI_HTTP_MAX_CONNECTIONS=40
AI_HTTP_MAX_KEEPALIVE=20
AI_HTTP_KEEPALIVE_EXPIRY=45
AI_TIMEOUT_ACTION_PARSER=8
AI_TIMEOUT_OBSERVATION=12
AI_TIMEOUT_NPC=18
AI_TIMEOUT_GM=25
AI_TIMEOUT_DEFAULT=20
AI_ACTION_PARSER_MODE=fast
AI_REFINE_WORLD_STATE=false

DEEPSEEK_ROLE_KAREN_API_KEY=
DEEPSEEK_ROLE_ELIAS_API_KEY=
DEEPSEEK_ROLE_MORGAN_API_KEY=
DEEPSEEK_ROLE_ALBERT_API_KEY=
DEEPSEEK_ROLE_LINOR_API_KEY=
DEEPSEEK_ROLE_KALON_API_KEY=
DEEPSEEK_ROLE_VINCENT_API_KEY=
